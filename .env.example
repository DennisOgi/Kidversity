# Supabase Configuration
# Dashboard → Settings → API → Project URL + anon/public key (NOT the service_role secret)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=eyJhbGci...your_anon_key_here

# OpenAI Configuration (for AI lesson generation)
OPENAI_API_KEY=your_openai_api_key_here

# Sentry Configuration (for error tracking)
SENTRY_DSN=your_sentry_dsn_here

# Environment
ENVIRONMENT=development

# API Configuration
API_BASE_URL=https://api.kidversity.app
API_TIMEOUT_SECONDS=30
